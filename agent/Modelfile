FROM qwen2.5:72b

# Switched from Nemotron 3 Super 120B — too slow for real-time voice turns.
# Qwen2.5-72B: best-in-class tool calling, ~45GB, ~3x faster on GB10 unified memory.
PARAMETER temperature 0.3
PARAMETER top_p 0.9
PARAMETER top_k 40
PARAMETER num_ctx 8192
PARAMETER repeat_penalty 1.1
PARAMETER num_predict 1024

# Stop tokens for Nemotron / Llama-3 base
PARAMETER stop "<|end_of_text|>"
PARAMETER stop "<|eot_id|>"
PARAMETER stop "<|im_end|>"

# System prompt is injected at agent runtime by donna.yaml — leave blank here
SYSTEM ""
