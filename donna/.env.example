# Donna AI Legal Secretary — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── LLM (Ollama — runs locally, no API key needed) ───────────────────────────
OLLAMA_BASE_URL=http://localhost:11434
DONNA_LLM_MODEL=qwen2.5:72b

# ── Speech-to-Text (faster-whisper-server) ────────────────────────────────────
WHISPER_URL=http://localhost:9000
WHISPER_MODEL=Systran/faster-distil-whisper-large-v3

# ── Text-to-Speech ────────────────────────────────────────────────────────────
TTS_ENGINE=kokoro
KOKORO_URL=http://localhost:8880
KOKORO_VOICE=af_heart
# PIPER_MODEL=en_US-lessac-medium.onnx  # fallback TTS

# ── Dashboard ─────────────────────────────────────────────────────────────────
DASHBOARD_WS_URL=ws://localhost:3001

# ── Database ──────────────────────────────────────────────────────────────────
DONNA_DB_PATH=./knowledge/donna.db

# ── Email account (used for BOTH inbound IMAP polling AND outbound SMTP) ─────
# Gmail: enable 2FA, create App Password at:
#   https://myaccount.google.com/apppasswords → select "Mail"
# Outlook: use your normal password (or app password if MFA enabled).
DONNA_EMAIL_USER=intake@lawfirm.com
DONNA_EMAIL_PASS=your-app-password-here

# Inbound mode: smtp (local listener on port 1025) or imap (poll every 30s)
DONNA_EMAIL_MODE=smtp

# ── IPC endpoints ─────────────────────────────────────────────────────────────
# M1's session router — plain email body text arrives here as user_input.
# Also receives email_draft_pending / email_sent notifications.
DONNA_SESSION_ROUTER_URL=http://localhost:8000/ipc
# VLM document pipeline — attachments arrive here as document_ingest
DONNA_PIPELINE_INGEST_URL=http://localhost:8765/ingest

# ── Storage ───────────────────────────────────────────────────────────────────
# Inbound attachments: saved to {DONNA_ATTACHMENT_DIR}/{case_id}/{filename}
DONNA_ATTACHMENT_DIR=/gbio/donna/documents

# Outbound drafts awaiting approval: {DONNA_DRAFTS_DIR}/{case_id}/{draft_id}.json
DONNA_DRAFTS_DIR=/gbio/donna/drafts

# Sent email archive: {DONNA_SENT_DIR}/{case_id}/{draft_id}.json
DONNA_SENT_DIR=/gbio/donna/sent

# ── Outbound SMTP (override config.yaml defaults) ────────────────────────────
# Gmail:   DONNA_SMTP_HOST=smtp.gmail.com   DONNA_SMTP_PORT=587
# Outlook: DONNA_SMTP_HOST=smtp.office365.com  DONNA_SMTP_PORT=587
# Postfix: DONNA_SMTP_HOST=localhost  DONNA_SMTP_PORT=25
# Credentials are reused from DONNA_EMAIL_USER / DONNA_EMAIL_PASS above.
DONNA_SMTP_HOST=smtp.gmail.com
DONNA_SMTP_PORT=587

# ── Auth (optional) ───────────────────────────────────────────────────────────
# Shared secret sent as X-Donna-Secret header on IPC calls
DONNA_IPC_SECRET=

# ── VLM ───────────────────────────────────────────────────────────────────────
DONNA_VLM_MODEL=qwen2.5-vl:latest

# ── OpenClaw ──────────────────────────────────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=
COURTLISTENER_TOKEN=
GBRAIN_DSN=postgresql://donna@localhost:7700/donna
