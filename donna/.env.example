# Donna AI Legal Secretary — Environment Variables
# Copy to .env and fill in values

# LLM (Ollama — runs locally, no API key needed)
OLLAMA_BASE_URL=http://localhost:11434
DONNA_LLM_MODEL=nemotron:120b

# Speech-to-Text (faster-whisper-server Docker)
WHISPER_URL=http://localhost:9000
WHISPER_MODEL=Systran/faster-distil-whisper-large-v3

# Text-to-Speech
TTS_ENGINE=kokoro
KOKORO_URL=http://localhost:8880
KOKORO_VOICE=af_heart
# PIPER_MODEL=en_US-lessac-medium.onnx  # fallback TTS

# Vector Database
CHROMA_HOST=localhost
CHROMA_PORT=8001

# SQLite Database
DONNA_DB_PATH=./knowledge/donna.db

# Dashboard
DASHBOARD_WS_URL=ws://localhost:3001

# Wake Word (optional: path to custom "hey_donna" model)
# DONNA_WAKEWORD_MODEL=./models/hey_donna.onnx
