# Donna AI Legal Secretary — Environment Variables
# Copy to .env and fill in values. Never commit .env to git.

# ── LLM (Ollama — runs locally, no API key needed) ───────────────────────────
DONNA_OLLAMA_URL=http://localhost:11434
DONNA_MODEL=qwen2.5:32b
# Used by agent_bridge.py (IPC/email path) — same model as above
DONNA_LLM_MODEL=qwen2.5:32b

# ── Speech-to-Text (faster-whisper-server on :9000) ──────────────────────────
DONNA_STT_URL=http://localhost:9000/v1/audio/transcriptions
DONNA_STT_MODEL=Systran/faster-distil-whisper-large-v3

# ── Text-to-Speech (Kokoro on :8880, Piper fallback) ─────────────────────────
DONNA_KOKORO_URL=http://localhost:8880/v1/audio/speech
DONNA_KOKORO_VOICE=af_heart
# DONNA_PIPER_MODEL=en_US-amy-medium  # fallback TTS

# ── Dashboard WebSocket hub ───────────────────────────────────────────────────
DONNA_DASHBOARD_WS=ws://localhost:3001

# ── Database paths ────────────────────────────────────────────────────────────
DONNA_TELEPHONY_DB=data/donna_telephony.sqlite
DONNA_CONTEXT_DB=data/donna_m3_context.sqlite
DONNA_CALENDAR_DB=data/donna_m3_calendar.sqlite
DONNA_DB_PATH=./donna/knowledge/donna.db

# ── Telephony server ──────────────────────────────────────────────────────────
DONNA_TELEPHONY_PORT=3002
# Set to your ngrok/public URL when using Twilio (no trailing slash)
PUBLIC_URL=https://YOUR-NGROK-ID.ngrok-free.app

# ── Twilio (required for real phone calls) ────────────────────────────────────
# Get these from console.twilio.com → Account Info
TWILIO_ACCOUNT_SID=ACxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxxx
TWILIO_AUTH_TOKEN=your_auth_token_here
TWILIO_PHONE_NUMBER=+1XXXXXXXXXX
# Set to "false" to skip Twilio signature validation during local testing
DONNA_VALIDATE_TWILIO=true

# ── Firm name (shown in Donna's greeting) ─────────────────────────────────────
DONNA_FIRM_NAME=Donna Legal

# ── Email account (inbound IMAP polling AND outbound SMTP) ───────────────────
# Gmail: enable 2FA, create App Password at myaccount.google.com/apppasswords
DONNA_EMAIL_USER=intake@lawfirm.com
DONNA_EMAIL_PASS=your-app-password-here

# Inbound mode: smtp (local listener on port 1025) or imap (poll every 30s)
DONNA_EMAIL_MODE=smtp

# ── IPC endpoints ─────────────────────────────────────────────────────────────
DONNA_SESSION_ROUTER_URL=http://localhost:8000/ipc
DONNA_PIPELINE_INGEST_URL=http://localhost:8765/ingest

# ── Storage paths ─────────────────────────────────────────────────────────────
DONNA_ATTACHMENT_DIR=/gbio/donna/documents
DONNA_DRAFTS_DIR=/gbio/donna/drafts
DONNA_SENT_DIR=/gbio/donna/sent

# ── Outbound SMTP ─────────────────────────────────────────────────────────────
# Gmail:   DONNA_SMTP_HOST=smtp.gmail.com   DONNA_SMTP_PORT=587
# Outlook: DONNA_SMTP_HOST=smtp.office365.com  DONNA_SMTP_PORT=587
DONNA_SMTP_HOST=smtp.gmail.com
DONNA_SMTP_PORT=587

# ── Auth (optional) ───────────────────────────────────────────────────────────
DONNA_IPC_SECRET=

# ── VLM (document ingest) ────────────────────────────────────────────────────
DONNA_VLM_MODEL=qwen2.5vl:7b

# ── OpenClaw / CourtListener (optional) ──────────────────────────────────────
OPENCLAW_GATEWAY_TOKEN=
COURTLISTENER_TOKEN=
GBRAIN_DSN=postgresql://donna@localhost:7700/donna
