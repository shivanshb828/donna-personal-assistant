# Donna Email Server — copy to /gbio/donna/.env and fill in real values.
# Never commit .env to git.

# ── IMAP credentials (required for imap mode) ──────────────────────────────
# Gmail: enable 2FA, then create an App Password at:
#   https://myaccount.google.com/apppasswords → select "Mail"
# Outlook: use your normal password (or app password if MFA is enabled).
DONNA_EMAIL_USER=intake@lawfirm.com
DONNA_EMAIL_PASS=your-app-password-here

# ── Endpoints ────────────────────────────────────────────────────────────────
# M1's session router — plain email body text goes here as user_input.
DONNA_SESSION_ROUTER_URL=http://localhost:8000/ipc

# VLM document pipeline — attachments go here as document_ingest.
DONNA_PIPELINE_INGEST_URL=http://localhost:8765/ingest

# ── Storage ──────────────────────────────────────────────────────────────────
# Attachments saved to {DONNA_ATTACHMENT_DIR}/{case_id}/{filename}
# Must match what the VLM pipeline expects to find files at.
DONNA_ATTACHMENT_DIR=/gbio/donna/documents

# ── ngrok / auth (optional) ──────────────────────────────────────────────────
# If M1 enforces a shared secret on the /ipc endpoint, set it here.
# Email server sends it as: X-Donna-Secret: <token>
DONNA_IPC_SECRET=
